# Docker-Claw 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# =================================
# GitHub配置（必需）
# =================================

# GitHub Personal Access Token
# 获取方式: https://github.com/settings/tokens
# 需要权限: repo, read:org, write:discussion
GITHUB_TOKEN=your_github_token_here

# GitHub仓库（格式: owner/repo）
GITHUB_REPO=yourname/yourrepo

# =================================
# 智谱AI配置（必需）
# =================================

# 智谱AI API Key
# 获取方式: https://open.bigmodel.cn/
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenClaw模型配置（可选）
# 默认: zhipu/glm-4
# 可选: zhipu/glm-4-plus, zhipu/glm-4-flash
OPENCLAW_MODEL=zhipu/glm-4

# =================================
# Git配置（可选）
# =================================

# Git用户名（用于commit）
GIT_USER_NAME=K哥

# Git邮箱（用于commit）
GIT_USER_EMAIL=your@email.com

# =================================
# 工作目录配置（可选）
# =================================

# 工作空间路径（Git仓库根目录）
# 默认: ./workspace
WORKSPACE_PATH=/path/to/your/workspace

# =================================
# 高级配置（可选）
# =================================

# OpenClaw Gateway端口
# OPENCLAW_GATEWAY_PORT=3000

# 日志级别
# LOG_LEVEL=info

# Agent心跳间隔（毫秒）
# HEARTBEAT_INTERVAL=600000

# Cron任务间隔（毫秒）
# CRON_INTERVAL=300000
