# Docker-Claw 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# =================================
# GitHub配置（必需）
# =================================

# GitHub Personal Access Token
# 获取方式: https://github.com/settings/tokens
# 需要权限: repo, read:org, write:discussion
GITHUB_TOKEN=your_github_token_here

# =================================
# 刚子配置 - Kimi（月之暗面）
# =================================

# Kimi API Key
# 获取方式: https://platform.moonshot.cn/
GANGZI_API_KEY=your_kimi_api_key_here

# 刚子使用的模型
# 可选: moonshot/kimi-k2.5, moonshot/kimi-k2-thinking
GANGZI_MODEL=moonshot/kimi-k2.5

# =================================
# 煎饼配置 - MiniMax
# =================================

# MiniMax API Key
# 获取方式: https://www.minimaxi.com/
JIANBING_API_KEY=your_minimax_api_key_here

# 煎饼使用的模型
# 可选: minimax/MiniMax-M2.5, minimax/MiniMax-M2.5-highspeed
JIANBING_MODEL=minimax/MiniMax-M2.5

# =================================
# 墨汁儿配置 - 智谱GLM
# =================================

# 智谱AI API Key
# 获取方式: https://open.bigmodel.cn/
MOZHI_API_KEY=your_zhipu_api_key_here

# 墨汁儿使用的模型
# 可选: zhipu/glm-5, zhipu/glm-4-plus, zhipu/glm-4-flash
MOZHI_MODEL=zhipu/glm-5

# =================================
# 飞书配置（可选，用于刚子与用户通讯）
# =================================

# 飞书应用 App ID
# 获取方式: https://open.feishu.cn/app -> 创建企业自建应用 -> 凭证与基础信息
FEISHU_APP_ID=your_feishu_app_id_here

# 飞书应用 App Secret
FEISHU_APP_SECRET=your_feishu_app_secret_here

# =================================
# Git配置（可选）
# =================================

# 通用Git邮箱（用于所有Agent的commit）
GIT_USER_EMAIL=your@email.com

# 刚子Git用户名
GANGZI_GIT_NAME=Gangzi

# 煎饼Git用户名
JIANBING_GIT_NAME=Jianbing

# 墨汁儿Git用户名
MOZHI_GIT_NAME=Mozhi

# =================================
# 工作目录配置（可选）
# =================================

# 工作空间路径（Git仓库根目录）
# 默认: ./workspace
WORKSPACE_PATH=./workspace

# =================================
# 高级配置（可选）
# =================================

# OpenClaw Gateway端口
# OPENCLAW_GATEWAY_PORT=3000

# 日志级别
# LOG_LEVEL=info

# Agent心跳间隔（毫秒）
# HEARTBEAT_INTERVAL=600000

# Cron任务间隔（毫秒）
# CRON_INTERVAL=300000
